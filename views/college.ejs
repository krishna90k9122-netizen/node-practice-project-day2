<!DOCTYPE html>
<html>
<head>
    <title>College Data</title>
</head>
<body>

    <table border="1">
        <tr>
            <th>Name</th>
            <th>Age</th>
        </tr>

        <% result.forEach((result) => { %>
            <tr>
                <td><%= result.name %></td>
                <td><%= result.age %></td>
            </tr>
        <% }) %>

    </table>

</body>
</html>